{
  "appId": "fr.vigiecity.app",
  "appName": "VigieCity",
  "webDir": "dist",
  "bundledWebRuntime": false,
  "server": {
    "url": "https://vigiecity.fr/auth",
    "androidScheme": "https",
    "iosScheme": "https",
    "allowNavigation": ["*.vigiecity.fr", "*.supabase.co", "*.vercel.app"]
  },
  "android": {
    "backgroundColor": "#091844",
    "allowMixedContent": false,
    "captureInput": true,
    "webContentsDebuggingEnabled": false
  },
  "ios": {
    "backgroundColor": "#091844",
    "contentInset": "automatic",
    "scrollEnabled": true
  },
  "plugins": {
    "PushNotifications": {
      "presentationOptions": ["badge", "sound", "alert"]
    },
    "App": {
      "exitOnBackButton": false
    },
    "Camera": {
      "permissions": ["camera", "photos"]
    },
    "Geolocation": {
      "permissions": ["location"]
    },
    "SplashScreen": {
      "launchShowDuration": 2000,
      "launchAutoHide": true,
      "backgroundColor": "#091844",
      "androidSpinnerStyle": "large",
      "iosSpinnerStyle": "small",
      "spinnerColor": "#3b82f6",
      "showSpinner": true
    }
  }
}
